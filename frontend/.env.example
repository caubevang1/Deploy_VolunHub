# Frontend
# Backend origin only (without /api), e.g. https://volunteerhub-api.onrender.com
VITE_API_URL=https://your-backend.onrender.com

# Optional: if your build pipeline still expects this name
# VITE_API_BASE_URL=https://your-backend.onrender.com

# Optional: VAPID key for build-time injection (notificationService also can fetch from backend)
# VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
